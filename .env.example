# DivorceOS Environment Variables

# Kimi K2.5 API (Moonshot AI)
# Get your API key from: https://platform.moonshot.cn/
VITE_KIMI_API_KEY=your_kimi_api_key_here
VITE_KIMI_API_URL=https://api.moonshot.cn/v1/chat/completions

# Stripe Payment API
# Get your keys from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
VITE_STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe Price IDs for subscription plans
VITE_STRIPE_PRICE_ESSENTIAL=price_essential_plan_id
VITE_STRIPE_PRICE_PLUS=price_plus_plan_id
VITE_STRIPE_PRICE_DONE_FOR_YOU=price_done_for_you_id

# Tavily Browser API (AI-powered web search)
# Get your API key from: https://tavily.com/
VITE_TAVILY_API_KEY=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

# AgentMail.to API (for agent messaging)
# Get your API key from: https://agentmail.to
VITE_AGENTMAIL_API_KEY=am_us_8764650c38e114701f4fb86b24edd93eed7238f401afb16cc94fed12d07a911b

# Google Analytics (optional)
